{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@11.0.9",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "pnpm run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": " wrangler types && wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "pnpx @biomejs/biome lint && pnpx @biomejs/biome check",
		"format": "pnpx @biomejs/biome lint --write && pnpx @biomejs/biome check --write",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"gen": "wrangler types",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/js-search": "^1.4.4",
		"@types/node": "^24.13.3",
		"@vitest/browser-playwright": "^4.1.10",
		"create-cloudflare": "^2.70.10",
		"daisyui": "^5.6.16",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.2.1",
		"wrangler": "^4.110.0"
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"@microsoft/signalr": "^10.0.0",
		"js-search": "^2.0.1",
		"ky": "^2.0.2",
		"svelte-easy-crop": "^5.0.1",
		"svelte-persisted-store": "^0.12.0",
		"ts-results-es": "^7.1.0",
		"tslib": "^2.8.1"
	}
}
